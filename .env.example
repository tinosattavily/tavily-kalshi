# Tavily Kalshi Signals - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# REQUIRED API KEYS
# ============================================

# OpenAI API Key (Required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (Required)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# MongoDB Connection String (Required)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGODB_URI=your_mongodb_connection_string_here

# ============================================
# KALSHI API CONFIGURATION
# ============================================

# Kalshi API Key ID (Required for Kalshi integration)
# Get your API key from: https://kalshi.com/account/api
KALSHI_API_KEY_ID=your_kalshi_api_key_id_here

# Kalshi Private Key (Required - choose ONE option)
# Option 1: Path to your private key file (PEM format)
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem

# Option 2: Base64-encoded private key (alternative to file path)
# Useful for containerized deployments where file mounts are inconvenient
# KALSHI_PRIVATE_KEY_BASE64=your_base64_encoded_private_key_here

# Kalshi Environment (Optional, defaults to "demo")
# Options: demo, production
# Use "demo" for testing with paper trading, "production" for live markets
KALSHI_ENV=demo

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Logging Level (Optional, defaults to INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Redis Cache Configuration (Optional)
# Set to true to use Redis for caching, false to use in-memory cache
USE_REDIS_CACHE=false

# Redis Connection (Optional, required if USE_REDIS_CACHE=true)
# Option 1: Use REDIS_URL (recommended)
REDIS_URL=redis://localhost:6379/0

# Option 2: Use individual settings (alternative to REDIS_URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# CORS Origins (Optional, defaults to http://localhost:3000)
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ============================================
# FRONTEND CONFIGURATION (Optional)
# ============================================

# Backend URL for frontend API calls (Optional, defaults to http://localhost:8000)
# Set this if your backend is hosted elsewhere
BACKEND_URL=http://localhost:8000
